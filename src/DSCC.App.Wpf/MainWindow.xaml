                                                <TextBox Text="{Binding ElementName=StationList, Path=SelectedItem.FootMarkerZ, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Style="{StaticResource MonoText}" Foreground="{StaticResource Ink2Brush}" Margin="0,0,0,12">
                                            <Run Text="live pelvis " Foreground="{StaticResource Ink3Brush}" />
                                            <Run Text="{Binding ElementName=StationList, Path=SelectedItem.PelvisX, StringFormat={}{0:0.000}, Mode=OneWay}" />
                                            <Run Text=", " />
                                            <Run Text="{Binding ElementName=StationList, Path=SelectedItem.PelvisY, StringFormat={}{0:0.000}, Mode=OneWay}" />
                                            <Run Text=", " />
                                            <Run Text="{Binding ElementName=StationList, Path=SelectedItem.PelvisZ, StringFormat={}{0:0.000}, Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock Text="추적 ROI (m)" Style="{StaticResource HintText}" Margin="0,0,0,8" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="X" Style="{StaticResource HintText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ElementName=StationList, Path=SelectedItem.RoiMinX, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding ElementName=StationList, Path=SelectedItem.RoiMaxX, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="1" Text="Y" Style="{StaticResource HintText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ElementName=StationList, Path=SelectedItem.RoiMinY, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding ElementName=StationList, Path=SelectedItem.RoiMaxY, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="2" Text="Z" Style="{StaticResource HintText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ElementName=StationList, Path=SelectedItem.RoiMinZ, UpdateSourceTrigger=LostFocus}" />
                                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding ElementName=StationList, Path=SelectedItem.RoiMaxZ, UpdateSourceTrigger=LostFocus}" />
                                        </Grid>

                                        <TextBlock Text="Unity anchor" Style="{StaticResource HintText}" Margin="0,0,0,8" />
                                        <UniformGrid Columns="4" Margin="0,0,0,14">
                                            <TextBox Text="{Binding ElementName=StationList, Path=SelectedItem.UnityAnchorX, UpdateSourceTrigger=LostFocus}" Margin="0,0,6,0" />
                                            <TextBox Text="{Binding ElementName=StationList, Path=SelectedItem.UnityAnchorY, UpdateSourceTrigger=LostFocus}" Margin="0,0,6,0" />
                                            <TextBox Text="{Binding ElementName=StationList, Path=SelectedItem.UnityAnchorZ, UpdateSourceTrigger=LostFocus}" Margin="0,0,6,0" />
                                            <TextBox Text="{Binding ElementName=StationList, Path=SelectedItem.UnityRotationY, UpdateSourceTrigger=LostFocus}" />
                                        </UniformGrid>

                                        <UniformGrid Columns="2" Rows="3">
                                            <Button Content="발 마커 캡처" Style="{StaticResource CommandTile}" Command="{Binding CaptureFootMarkerCommand}" CommandParameter="{Binding ElementName=StationList, Path=SelectedItem.StationId}" Margin="0,0,8,8" />
                                            <Button Content="ROI 자동 생성" Style="{StaticResource CommandTile}" Command="{Binding GenerateRoiCommand}" CommandParameter="{Binding ElementName=StationList, Path=SelectedItem.StationId}" Margin="0,0,0,8" />
                                            <Button Content="현재 위치로 맞춤" Style="{StaticResource CommandTile}" Command="{Binding CaptureLivePoseCommand}" CommandParameter="{Binding ElementName=StationList, Path=SelectedItem.StationId}" Margin="0,0,8,8" />
                                            <Button Content="선택 Station 적용" Style="{StaticResource CommandTile}" Foreground="{StaticResource OkBrush}" Command="{Binding ApplyStationEditorCommand}" CommandParameter="{Binding ElementName=StationList, Path=SelectedItem.StationId}" Margin="0,0,0,8" />
                                            <Button Content="전체 설정 저장" Style="{StaticResource CommandTile}" Foreground="{StaticResource OkBrush}" Command="{Binding SaveConfigCommand}" />
                                        </UniformGrid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{StaticResource Rule0Brush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <Border Style="{StaticResource SectionHeader}">
                                        <DockPanel VerticalAlignment="Center">
                                            <TextBlock DockPanel.Dock="Right" Text="▾" Foreground="{StaticResource Ink3Brush}" />
                                            <TextBlock Text="임계값" Style="{StaticResource DisplayText}" FontSize="13" />
                                        </DockPanel>
                                    </Border>
                                    <StackPanel Margin="20,14,20,18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="진입 안정 (s)" Style="{StaticResource HintText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ElementName=StationList, Path=SelectedItem.EnterStableSeconds, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="1" Text="Lost 유예 (s)" Style="{StaticResource HintText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ElementName=StationList, Path=SelectedItem.LostGraceSeconds, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="2" Text="이탈 확정 (s)" Style="{StaticResource HintText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ElementName=StationList, Path=SelectedItem.ExitConfirmSeconds, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="3" Text="최소 confidence" Style="{StaticResource HintText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ElementName=StationList, Path=SelectedItem.MinSkeletonConfidence, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="4" Text="발 마커 반경 (m)" Style="{StaticResource HintText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ElementName=StationList, Path=SelectedItem.FootMarkerRadiusMeters, UpdateSourceTrigger=LostFocus}" />
                                        </Grid>
                                        <TextBlock Text="{Binding ElementName=StationList, Path=SelectedItem.ConditionSummary}" Style="{StaticResource MonoText}" Foreground="{StaticResource Ink2Brush}" TextWrapping="Wrap" Margin="0,12,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{StaticResource Rule0Brush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <Border Style="{StaticResource SectionHeader}">
                                        <DockPanel VerticalAlignment="Center">
                                            <TextBlock DockPanel.Dock="Right" Text="▾" Foreground="{StaticResource Ink3Brush}" />
                                            <TextBlock Text="Unity Link" Style="{StaticResource DisplayText}" FontSize="13" />
                                        </DockPanel>
                                    </Border>
                                    <StackPanel Margin="20,14,20,18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="92" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Target IP" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                                <TextBox Text="{Binding UnityHost, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Skeleton" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                                <TextBox Text="{Binding SkeletonPort, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Event port" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                                <TextBox Text="{Binding EventPort, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Status port" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                                <TextBox Text="{Binding StatusPort, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                        </Grid>
                                        <CheckBox Content="Mirror skeleton X for front-facing camera"
                                                  IsChecked="{Binding MirrorSkeletonForUnity}"
                                                  Margin="0,12,0,0" />
                                        <CheckBox Content="Stabilize head and neck rotation"
                                                  IsChecked="{Binding StabilizeHeadRotation}"
                                                  Margin="0,8,0,0" />
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="10" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Head smooth (s)" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                                <TextBox Text="{Binding HeadRotationSmoothingHalfLifeSeconds, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Max deg/sec" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                                <TextBox Text="{Binding HeadRotationMaxDegreesPerSecond, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2">
                                                <TextBlock Text="Min conf" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                                <TextBox Text="{Binding HeadRotationMinConfidence, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="Deadzone deg" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                                                <TextBox Text="{Binding HeadRotationDeadZoneDegrees, UpdateSourceTrigger=LostFocus}" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Margin="0,12,0,10" Style="{StaticResource MonoText}">
                                            <Run Text="last frame " Foreground="{StaticResource Ink3Brush}" /><Run Text="{Binding LastSentTimestamp, Mode=OneWay}" Foreground="{StaticResource Ink0Brush}" />
                                        </TextBlock>
                                        <UniformGrid Columns="2" Rows="3">
                                            <Button Content="game/start" Style="{StaticResource CommandTile}" Foreground="{StaticResource OkBrush}" Command="{Binding SendEventCommand}" CommandParameter="game/start" Margin="0,0,8,8" />
                                            <Button Content="game/reset" Style="{StaticResource CommandTile}" Foreground="{StaticResource WarnBrush}" Command="{Binding SendEventCommand}" CommandParameter="game/reset" Margin="0,0,0,8" />
                                            <Button Content="player/enter" Style="{StaticResource CommandTile}" Command="{Binding SendEventCommand}" CommandParameter="player/enter" Margin="0,0,8,8" />
                                            <Button Content="player/exit" Style="{StaticResource CommandTile}" Command="{Binding SendEventCommand}" CommandParameter="player/exit" Margin="0,0,0,8" />
                                            <Button Content="calibration/reload" Style="{StaticResource CommandTile}" Command="{Binding SendEventCommand}" CommandParameter="calibration/reload" Margin="0,0,8,0" />
                                            <Button Content="강제 이탈" Style="{StaticResource CommandTile}" Foreground="{StaticResource ErrorBrush}" Command="{Binding ForceExitCommand}" CommandParameter="{Binding ElementName=StationList, Path=SelectedItem.StationId}" />
                                        </UniformGrid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="5" Background="{StaticResource Paper0Brush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Style="{StaticResource MonoText}" Foreground="{StaticResource Ink1Brush}">
                        <Run Text="app " Foreground="{StaticResource Ink3Brush}" /><Run Text="정상" />
                    </TextBlock>
                    <TextBlock Text="   " />
                    <TextBlock Style="{StaticResource MonoText}" Foreground="{StaticResource Ink1Brush}">
                        <Run Text="skeleton " Foreground="{StaticResource Ink3Brush}" /><Run Text="UDP :" /><Run Text="{Binding SkeletonPort, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding SendFps, Mode=OneWay}" /><Run Text=" fps" />
                    </TextBlock>
                    <TextBlock Text="   " />
                    <TextBlock Style="{StaticResource MonoText}" Foreground="{StaticResource Ink1Brush}">
                        <Run Text="event " Foreground="{StaticResource Ink3Brush}" /><Run Text="UDP :" /><Run Text="{Binding EventPort, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Text="   " />
                    <TextBlock Style="{StaticResource MonoText}" Foreground="{StaticResource Ink1Brush}">
                        <Run Text="sent " Foreground="{StaticResource Ink3Brush}" /><Run Text="{Binding PacketsSent, Mode=OneWay}" /><Run Text=" / errors " Foreground="{StaticResource Ink3Brush}" /><Run Text="{Binding PacketErrors, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
                <TextBlock Grid.Column="1" Style="{StaticResource MonoText}" Foreground="{StaticResource Ink3Brush}" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Run Text="unity " /><Run Text="{Binding UnityStatus, Mode=OneWay}" /><Run Text=" · last frame " /><Run Text="{Binding LastSentTimestamp, Mode=OneWay}" /><Run Text=" · .NET 10 · WPF" />
                </TextBlock>
            </Grid>
    </Grid>
</Window>
