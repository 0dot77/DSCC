                                                                                    MouseLeftButtonDown="EditorRoi_MouseLeftButtonDown">
                                                                                <TextBlock Text="ROI" Style="{StaticResource MonoText}" FontSize="9" Foreground="{StaticResource Ink2Brush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,3,0,0" />
