<Window x:Class="DSCC.App.Wpf.MainWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DSCC.App.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Dance Station Control Center"
        Height="860"
        Width="1480"
        MinHeight="760"
        MinWidth="1180"
        Background="{DynamicResource AppShellBrush}"
        FontFamily="Inter, Pretendard, Segoe UI, Malgun Gothic"
        FontSize="12">
    <Window.Resources>
        <!-- Hallmark pre-emit critique: P5 H5 E4 S5 R5 V4
             macrostructure: Workbench (3-pane operations console)
             genre: modern-minimal; theme: custom dark instrument panel
             source: spec/design/dscc_wpf_mockup.html -->
        <SolidColorBrush x:Key="AppShellBrush" Color="#111318" />
        <SolidColorBrush x:Key="Paper0Brush" Color="#181B20" />
        <SolidColorBrush x:Key="Paper1Brush" Color="#20242A" />
        <SolidColorBrush x:Key="Paper2Brush" Color="#292E35" />
        <SolidColorBrush x:Key="Paper3Brush" Color="#343A43" />
        <SolidColorBrush x:Key="Paper4Brush" Color="#424A55" />
        <SolidColorBrush x:Key="Ink0Brush" Color="#F4F7FA" />
        <SolidColorBrush x:Key="Ink1Brush" Color="#C4CCD6" />
        <SolidColorBrush x:Key="Ink2Brush" Color="#8F9AAA" />
        <SolidColorBrush x:Key="Ink3Brush" Color="#687486" />
        <SolidColorBrush x:Key="Rule0Brush" Color="#39414B" />
        <SolidColorBrush x:Key="Rule1Brush" Color="#4C5662" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5EA7FF" />
        <SolidColorBrush x:Key="AccentDimBrush" Color="#1D3C5F" />
        <SolidColorBrush x:Key="AccentInkBrush" Color="#0E2034" />
        <SolidColorBrush x:Key="OkBrush" Color="#65D88D" />
        <SolidColorBrush x:Key="OkDimBrush" Color="#244C38" />
        <SolidColorBrush x:Key="WarnBrush" Color="#EBC667" />
        <SolidColorBrush x:Key="WarnDimBrush" Color="#51432A" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#F47A67" />
        <SolidColorBrush x:Key="ErrorDimBrush" Color="#55302D" />
        <SolidColorBrush x:Key="LostBrush" Color="#C487FF" />
        <SolidColorBrush x:Key="LostDimBrush" Color="#49345C" />
        <SolidColorBrush x:Key="MuteBrush" Color="#8994A3" />
        <SolidColorBrush x:Key="MuteDimBrush" Color="#303741" />

        <LinearGradientBrush x:Key="AccentFadeBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#203D5E" Offset="0" />
            <GradientStop Color="#292E35" Offset="0.45" />
            <GradientStop Color="#292E35" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="InspectorHeroBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#233326" Offset="0" />
            <GradientStop Color="#20242A" Offset="1" />
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="StageBrush" Center="0.5,0.35" GradientOrigin="0.5,0.35" RadiusX="0.82" RadiusY="0.72">
            <GradientStop Color="#2B323B" Offset="0" />
            <GradientStop Color="#181B20" Offset="1" />
        </RadialGradientBrush>
        <DrawingBrush x:Key="StageGridBrush" TileMode="Tile" Viewport="0,0,32,32" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Transparent">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,32,32" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#26303A" Thickness="1" />
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="0,32" />
                                <LineGeometry StartPoint="0,0" EndPoint="32,0" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <LinearGradientBrush x:Key="FovFillBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#005EA7FF" Offset="0" />
            <GradientStop Color="#335EA7FF" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ink0Brush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ink2Brush}" />
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ink3Brush}" />
        </Style>

        <Style x:Key="MonoText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Ink2Brush}" />
        </Style>

        <Style x:Key="DisplayText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Inter Tight, Pretendard, Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Ink0Brush}" />
        </Style>

        <Style x:Key="PaneBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Paper1Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>

        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource Paper1Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="DsccButton" TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{StaticResource Paper2Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Ink0Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle">
                <Setter.Value>
                    <Style TargetType="Control">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate>
                                    <Rectangle Stroke="{StaticResource AccentBrush}" StrokeThickness="2" RadiusX="5" RadiusY="5" Margin="-3" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource Paper3Brush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource Rule1Brush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource Paper4Brush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DsccButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentInkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DsccButton}">
            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource DsccButton}" />

        <Style x:Key="TopNavButton" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0,0" />
            <Setter Property="Margin" Value="0,0,24,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Ink1Brush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Ink0Brush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionNavButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0,0" />
            <Setter Property="Margin" Value="0,0,26,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Ink2Brush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SectionNavChrome" BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Ink0Brush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Ink0Brush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter TargetName="SectionNavChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Background" Value="{StaticResource Paper2Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Ink0Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Mono, Consolas" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Ink1Brush}" />
        </Style>

        <Style x:Key="ConsoleTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource Ink2Brush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,28,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabChrome"
                                Height="38"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Background="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource Ink0Brush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Ink1Brush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Ink3Brush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConsoleTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource Paper1Brush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ConsoleTabItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="38" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Background="{StaticResource Paper1Brush}" BorderBrush="{StaticResource Rule0Brush}" BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Margin="20,0,0,0" />
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="0" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StationListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StationCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Paper2Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentFadeBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StationAccentStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MuteBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Active">
                    <Setter Property="Background" Value="{StaticResource OkBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Entering">
                    <Setter Property="Background" Value="{StaticResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Lost">
                    <Setter Property="Background" Value="{StaticResource LostBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Error">
                    <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatePillStyle" TargetType="Border">
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{StaticResource MuteDimBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Active">
                    <Setter Property="Background" Value="{StaticResource OkDimBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource OkBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Entering">
                    <Setter Property="Background" Value="{StaticResource WarnDimBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Lost">
                    <Setter Property="Background" Value="{StaticResource LostDimBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LostBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Error">
                    <Setter Property="Background" Value="{StaticResource ErrorDimBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StateTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DisplayText}">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="{StaticResource MuteBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Active">
                    <Setter Property="Foreground" Value="{StaticResource OkBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Entering">
                    <Setter Property="Foreground" Value="{StaticResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Lost">
                    <Setter Property="Foreground" Value="{StaticResource LostBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Error">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChipBorder" TargetType="Border">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{StaticResource Paper2Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="CommandTile" TargetType="Button" BasedOn="{StaticResource DsccButton}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="MetricBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Foreground" Value="{StaticResource OkBrush}" />
            <Setter Property="Background" Value="{StaticResource Paper3Brush}" />
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" />
                            <Border x:Name="PART_Track" />
                            <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                <Border Background="{TemplateBinding Foreground}" CornerRadius="2" />
                            </Decorator>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="Background" Value="{StaticResource Paper1Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Ink1Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="{StaticResource Paper1Brush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource Paper0Brush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Mono, Consolas" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Paper0Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Ink2Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontFamily" Value="Inter, Pretendard, Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource Rule0Brush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="{StaticResource Ink1Brush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="LogLevelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MonoText}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="info">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="warn">
                    <Setter Property="Foreground" Value="{StaticResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="error">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Paper1Brush}" ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="30" />
                <RowDefinition Height="38" />
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource Paper0Brush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="DSCC" Style="{StaticResource DisplayText}" FontSize="13" FontWeight="Bold" />
                    <TextBlock Text="v0.1.0-mvp" Style="{StaticResource MonoText}" Margin="10,1,0,0" Foreground="{StaticResource Ink3Brush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource OkBrush}" Margin="0,0,8,0" />
                    <TextBlock Text="runtime" Style="{StaticResource MonoText}" Foreground="{StaticResource Ink2Brush}" />
                    <TextBlock Text=" live" Style="{StaticResource MonoText}" Foreground="{StaticResource Ink0Brush}" />
                    <TextBlock Text="  wall " Style="{StaticResource MonoText}" Foreground="{StaticResource Ink3Brush}" />
                    <TextBlock Text="{Binding WallId}" Style="{StaticResource MonoText}" Foreground="{StaticResource Ink0Brush}" />
                    <TextBlock Text="  config " Style="{StaticResource MonoText}" Foreground="{StaticResource Ink3Brush}" />
                    <TextBlock Text="{Binding ConfigPath}" Style="{StaticResource MonoText}" Foreground="{StaticResource Ink2Brush}" TextTrimming="CharacterEllipsis" MaxWidth="460" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Background="{StaticResource Paper1Brush}" Margin="16,0">
                <Menu Background="Transparent"
                      BorderThickness="0"
                      Foreground="{StaticResource Ink1Brush}"
                      Margin="-6,0,18,0"
                      VerticalAlignment="Center">
                    <MenuItem Header="File" Foreground="{StaticResource Ink1Brush}">
                        <MenuItem Header="Open config..." Command="{Binding OpenConfigCommand}" />
                        <MenuItem Header="Reload config" Command="{Binding RefreshConfigCommand}" />
                        <MenuItem Header="Save config" Command="{Binding SaveConfigCommand}" />
                        <MenuItem Header="Save config as..." Command="{Binding SaveConfigAsCommand}" />
                        <Separator />
                        <MenuItem Header="Revert" Command="{Binding RevertConfigCommand}" />
                        <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
                    </MenuItem>
                </Menu>
                <Button Content="Devices"
                        Style="{StaticResource TopNavButton}"
                        Tag="{Binding IsDevicesSelected}"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Devices" />
                <Button Content="Calibration"
                        Style="{StaticResource TopNavButton}"
                        Tag="{Binding IsCalibrationSelected}"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Calibration" />
                <Button Content="Unity"
                        Style="{StaticResource TopNavButton}"
                        Tag="{Binding IsUnityLinkSelected}"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="UnityLink" />
                <Button Content="Diagnostics"
                        Style="{StaticResource TopNavButton}"
                        Tag="{Binding IsDiagnosticsSelected}"
