                                <Grid.RowDefinitions>
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Style="{StaticResource SectionHeader}" BorderThickness="0,0,0,1">
                                    <DockPanel VerticalAlignment="Center">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Devices.Count, StringFormat={}{0} devices}" Style="{StaticResource MonoText}" Foreground="{StaticResource Ink3Brush}" />
                                        <TextBlock Text="Devices" Style="{StaticResource DisplayText}" FontSize="13" />
                                    </DockPanel>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Devices}" Margin="12,8">
