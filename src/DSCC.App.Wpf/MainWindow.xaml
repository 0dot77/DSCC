                                                        </TextBlock>
                                                        <TextBlock Style="{StaticResource MonoText}" Foreground="{StaticResource Ink3Brush}" Margin="0,6,0,0">
                                                            <Run Text="last " /><Run Text="{Binding LastFrameTime, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Margin="0,10,10,10" HorizontalAlignment="Right">
