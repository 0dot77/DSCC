                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock Text="*" Style="{StaticResource StateTextStyle}" Margin="0,0,5,0" />
                                                                <TextBlock Text="{Binding State}" Style="{StaticResource StateTextStyle}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Text="{Binding Confidence, StringFormat={}{0:0.00}}" HorizontalAlignment="Right" Margin="0,6,0,0">
