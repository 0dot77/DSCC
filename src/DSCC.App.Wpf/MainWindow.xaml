                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MonoText}">
                                                                    <Setter Property="Foreground" Value="{StaticResource Ink3Brush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding State}" Value="Active">
                                                                            <Setter Property="Foreground" Value="{StaticResource OkBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" BorderBrush="{StaticResource Rule0Brush}" BorderThickness="0,1,0,0">
